# Copy file ini jadi .env (atau export sebagai environment variable).
# Semua opsional — ada default per-OS.

# Host & port Chrome remote-debugging
CHROME_HOST=localhost
CHROME_PORT=9222

# Untuk VPS / Linux, set ini:
# CHROME_BIN=google-chrome
# CHROME_PROFILE=/home/username/.threads-bot-profile
# HEADLESS=true
